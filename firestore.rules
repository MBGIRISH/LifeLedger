rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: each user can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['name', 'email', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.email is string;
    }

    // Diary notes: users can only access their own notes as a sub-collection of users
    // IMPORTANT: Notes can NEVER be deleted
    match /users/{userId}/diary_notes/{noteId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['content', 'tag', 'date', 'createdAt', 'updatedAt'])
                    && request.resource.data.content is string
                    && request.resource.data.tag is string
                    && request.resource.data.date is string;

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.content is string
                    && request.resource.data.tag is string;

      // DELETE IS EXPLICITLY DENIED — diary notes must never be deleted
      allow delete: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
